{
    "i18n": true,
    "type": "panel",
    "items": {
        "username": {
            "type": "text",
            "label": "WeatherSense username (email)",
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4
        },
        "passwort": {
            "type": "text",
            "label": "WeatherSense password",
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4
        },
        "altitude_masl": {
            "type": "number",
            "label": "Meter above sea level",
            "default": 0,
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4
        },
        "celsius": {
            "type": "checkbox",
            "label": "°C (unchecked = °F)",
            "default": true,
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4
        },
        "rain_unit": {
            "type": "checkbox",
            "label": "Rain in mm (unchecked = inch)",
            "default": true,
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4
        },
        "wind_unit": {
            "type": "checkbox",
            "label": "Wind speed in km/h (unchecked = MPH)",
            "help": "The weather station determines the actual wind speed unit. This setting only controls which unit is shown in the data points",
            "default": true,
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4
        },
        "sensor_id": {
            "type": "number",
            "label": "Sensor ID (1-20)",
            "help": "help_sensor_id",
            "default": 1,
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4
        },
        "mqtt_active": {
            "type": "checkbox",
            "label": "Use MQTT",
            "default": false,
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4
        },
        "broker_address": {
            "type": "text",
            "label": "MQTT broker IP address",
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4,
            "hidden": "data.mqtt_active == false"
        },
        "mqtt_port": {
            "type": "number",
            "label": "MQTT port",
            "default": 1883,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4,
            "hidden": "data.mqtt_active == false"
        },
        "mqtt_user": {
            "type": "text",
            "label": "MQTT user. Leave blank for no-auth",
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4,
            "hidden": "data.mqtt_active == false"
        },
        "mqtt_pass": {
            "type": "text",
            "label": "MQTT password. Leave blank for no-auth",
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4,
            "hidden": "data.mqtt_active == false"
        },
        "storeJson": {
            "type": "checkbox",
            "label": "Save Json file",
            "default": false,
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4
        },
        "storeDir": {
            "type": "text",
            "label": "Folder for JSON file",
            "default": "/home/pi",
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4,
            "hidden": "data.storeJson == false"
        },
        "inversePowerStatus": {
            "type": "checkbox",
            "label": "Inverse PowerStatus warning",
            "default": false,
            "newLine": true,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4
        }
    }
}
